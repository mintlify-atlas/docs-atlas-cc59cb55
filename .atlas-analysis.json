  "keyFeatures": [
    "User authentication and registration with email verification",
    "Product catalog with filtering, search, and reviews",
    "Shopping cart and order management",
    "Event-driven architecture with Kafka integration",
    "Keycloak integration for backend authentication",
    "Product favorites and recommendations",
    "Email notifications via SMTP",
    "Event idempotency and retry mechanisms"
  ],
  "publicApiSurface": [
    "POST /auth/login - User login",
    "POST /auth/register - User registration",
    "POST /auth/verify-email - Email verification",
    "POST /auth/logout - User logout",
    "GET /products - List products with pagination",
    "GET /products/{id} - Get product details with related products",
    "POST /products/filter - Filter products by category, brand, price",
    "GET /products/search - Search products by query",
    "POST /products/code/{productCode}/review - Add product review",
    "POST /products/favourite/{productCode} - Add product to favorites",
    "DELETE /products/favourite/{productCode} - Remove product from favorites",
    "GET /cart - Get user's shopping cart",
    "POST /cart/item - Add item to cart",
    "PATCH /cart/item/{id} - Update cart item quantity",
    "DELETE /cart/item/{id} - Remove item from cart",
    "POST /purchase - Create new purchase order",
    "GET /purchase - List user purchases",
    "GET /purchase/{id} - Get purchase details",
    "PATCH /purchase/cancel/{id} - Cancel purchase",
    "GET /users/profile - Get user profile",
    "PATCH /users/profile - Update user profile",
    "GET /users/addresses - Get user addresses",
    "POST /users/addresses - Add new address",
    "GET /categories - List all categories",
    "GET /brands - List all brands"
  ]
}
